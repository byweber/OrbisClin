# ─────────────────────────────────────────────────────────────────
# OrbisClin — Exemplo de configuração de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA faça commit do arquivo .env no repositório.
# ─────────────────────────────────────────────────────────────────

# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=SUBSTITUA_POR_VALOR_ALEATORIO_FORTE

# Banco de dados (SQLite padrão, troque por PostgreSQL em produção)
DATABASE_URL=sqlite:///./orbisclin.db

# Diretório de armazenamento de arquivos
STORAGE_DIR=./storage

# Orthanc PACS
ORTHANC_URL=http://localhost:8042
ORTHANC_USER=orthanc
ORTHANC_PASS=orthanc

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0
